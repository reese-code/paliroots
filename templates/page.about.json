    "image_with_text_zEczj3": {
      "type": "image-with-text",
      "blocks": {
        "text_EpPehc": {
          "type": "text",
          "settings": {
            "text": "<p>We were born in Jerusalem and raised in the States—always finding new ways to feel close to home.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        },
        "text_aLjgJA": {
          "type": "text",
          "settings": {
            "text": "<p>For us, that connection came through food, through dance, through family stories passed down in pieces.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        },
        "text_bbtGN7": {
          "type": "text",
          "settings": {
            "text": "<p>PaliRoots began as a way to bring that feeling home.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        },
        "text_hrR8U4": {
          "type": "text",
          "settings": {
            "text": "<p>A bridge between here and there.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        },
        "text_K6ywnY": {
          "type": "text",
          "settings": {
            "text": "<p>Design and storytelling as a form of resistance—and celebration.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        },
        "text_Qcjeaa": {
          "type": "text",
          "settings": {
            "text": "<p>Because being Palestinian means carrying stories that were buried.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        },
        "text_HT3Yim": {
          "type": "text",
          "settings": {
            "text": "<p>Ours is to bring them back to life.</p>",
            "text_preset": "rte",
            "text_alignment": "left"
          }
        }
      },
