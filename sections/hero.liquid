{% comment %}
  PALIROOTS Custom Hero Section
  Hero section with image background and text content
{% endcomment %}

<div class="tw-relative tw-min-h-[70vh] tw-flex tw-items-center tw-bg-cover tw-bg-center tw-bg-no-repeat tw-overflow-hidden" style="
  {% if section.settings.hero_height %}min-height: {{ section.settings.hero_height }}vh;{% endif %}
">
  <!-- Hero Image -->
  {% if section.settings.hero_image != blank %}
    {{ section.settings.hero_image | image_url: width: 2048 | image_tag: class: 'tw-absolute tw-top-0 tw-left-0 tw-w-full tw-h-full tw-object-cover tw-z-[1]', alt: section.settings.hero_image.alt }}
  {% else %}
    <div class="tw-absolute tw-top-0 tw-left-0 tw-w-full tw-h-full tw-bg-gradient-to-br tw-from-indigo-500 tw-to-purple-600 tw-z-[1] tw-flex tw-items-center tw-justify-center tw-text-white tw-text-lg tw-font-medium">
      Add your hero image here
    </div>
  {% endif %}

  <!-- Hero Content -->
  <div class="tw-relative tw-z-[2] tw-max-w-[600px] tw-px-10 tw-text-white">
    {% if section.settings.hero_title != blank %}
      <h1 class="tw-text-[49px] tw-leading-[1.1] tw-mb-6 tw-font-medium tw-text-white">{{ section.settings.hero_title }}</h1>
    {% endif %}

    {% if section.settings.hero_description != blank %}
      <p class="tw-text-base tw-leading-relaxed tw-mb-8 tw-max-w-[500px] tw-text-white">{{ section.settings.hero_description }}</p>
    {% endif %}

    {% if section.settings.hero_button_text != blank and section.settings.hero_button_url != blank %}
      <a href="{{ section.settings.hero_button_url }}" class="tw-bg-white tw-text-black tw-px-8 tw-py-4 tw-rounded-md tw-no-underline tw-font-medium tw-text-base tw-inline-block tw-transition-all tw-duration-200 tw-border-2 tw-border-white hover:tw-bg-transparent hover:tw-text-white">
        {{ section.settings.hero_button_text }}
      </a>
    {% endif %}
  </div>
</div>

{%- style -%}
  @media screen and (max-width: 749px) {
    .hero-section .tw-text-\[49px\] {
      font-size: 36px !important;
    }
    
    .hero-section .tw-px-10 {
      padding-left: 20px !important;
      padding-right: 20px !important;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image",
      "info": "Recommended size: 2048x1024px or larger"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Shop Winter '24 Collection"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero Description",
      "default": "The iconic Pali Flag Sweatsuits are back and now available in kids sizes. Alongside them, discover nine new arrivals, blending timeless design with unmatched comfort for every day."
    },
    {
      "type": "text",
      "id": "hero_button_text",
      "label": "Button Text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "hero_button_url",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "hero_title": "Shop Winter '24 Collection",
        "hero_description": "The iconic Pali Flag Sweatsuits are back and now available in kids sizes. Alongside them, discover nine new arrivals, blending timeless design with unmatched comfort for every day.",
        "hero_button_text": "Shop now",
        "hero_button_url": "/collections/all"
      }
    }
  ]
}
{% endschema %}