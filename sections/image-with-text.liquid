{% stylesheet %}
  .image-with-text {
    display: flex;
    gap: var(--image-with-text-gap);
    align-items: center;
  }

  /* Layout direction control */
  .image-with-text--normal {
    flex-direction: row;
  }

  .image-with-text--flipped {
    flex-direction: row-reverse;
  }

  /* Responsive behavior */
  @media screen and (max-width: 749px) {
    .image-with-text,
    .image-with-text--flipped {
      flex-direction: column;
    }
  }

  /* Sizing options */
  .image-with-text--equal .image-with-text__image,
  .image-with-text--equal .image-with-text__content {
    flex: 1;
  }

  .image-with-text--text-one-third .image-with-text__content {
    flex: 1;
  }

  .image-with-text--text-one-third .image-with-text__image {
    flex: 2;
  }

  .image-with-text--image-one-third .image-with-text__image {
    flex: 1;
  }

  .image-with-text--image-one-third .image-with-text__content {
    flex: 2;
  }

  /* Image styling */
  .image-with-text__image {
    position: relative;
    overflow: hidden;
  }

  .image-with-text__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .image-with-text__image:hover img {
    transform: scale(1.02);
  }

  .image-with-text__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-foreground), 0.04);
    color: rgba(var(--color-foreground), 0.75);
    min-height: 400px;
    aspect-ratio: 4 / 3;
  }

  /* Content styling */
  .image-with-text__content {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap);
    padding: 1rem;
  }

  .image-with-text__text-item,
  .image-with-text__heading-item,
  .image-with-text__button-item {
    margin: 0;
  }

  .image-with-text__heading {
    margin: 0;
  }

  .image-with-text__text {
    margin: 0;
    line-height: 1.6;
  }

  .image-with-text__button {
    margin: 0;
  }

  /* Link wrapper */
  .image-with-text__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .image-with-text__content {
      padding: 1rem 0;
    }
    
    .image-with-text__placeholder {
      min-height: 300px;
    }
  }
{% endstylesheet %}

<div
  class="section section--{{ section.settings.section_width }} image-with-text-section spacing-style"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    {%- render 'border-override', settings: section.settings -%}
    --image-with-text-gap: {{ section.settings.gap }}px;
    --text-gap: {{ section.settings.text_gap }}px;
  "
>
  <div class="image-with-text image-with-text--{{ section.settings.layout_direction }} image-with-text--{{ section.settings.sizing_option }}">
    
    <!-- Image Section -->
    <div class="image-with-text__image">
      {% if section.settings.image %}
        {% if section.settings.image_link != blank %}
          <a href="{{ section.settings.image_link }}" class="image-with-text__link">
        {% endif %}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '300, 450, 600, 750, 900, 1050, 1200, 1350, 1500',
            sizes: 'auto, (min-width: 750px) 50vw, 100vw',
            alt: section.settings.image.alt | default: 'Featured image'
        }}
        {% if section.settings.image_link != blank %}
          </a>
        {% endif %}
      {% else %}
        <div class="image-with-text__placeholder">
          <span>Add Image</span>
        </div>
      {% endif %}
    </div>

    <!-- Content Section -->
    <div class="image-with-text__content">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'text' %}
            {% if block.settings.text != blank %}
              <div class="image-with-text__text-item" {{ block.shopify_attributes }}>
                <div class="text-block {{ block.settings.text_preset }}"
                  style="
                    text-align: {{ block.settings.text_alignment }};
                  "
                >
                  {% if block.settings.text_preset == 'rte' %}
                    <rte-formatter>{{ block.settings.text }}</rte-formatter>
                  {% else %}
                    {{ block.settings.text }}
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% when 'heading' %}
            {% if block.settings.heading != blank %}
              <div class="image-with-text__heading-item" {{ block.shopify_attributes }}>
                <{{ block.settings.heading_tag }} class="image-with-text__heading {{ block.settings.heading_tag }}"
                  style="
                    text-align: {{ block.settings.heading_alignment }};
                  "
                >
                  {{ block.settings.heading }}
                </{{ block.settings.heading_tag }}>
              </div>
            {% endif %}
          {% when 'button' %}
            {% if block.settings.button_label != blank %}
              <div class="image-with-text__button-item" {{ block.shopify_attributes }}>
                <div class="image-with-text__button"
                  style="
                    text-align: {{ block.settings.button_alignment }};
                  "
                >
                  <a 
                    href="{{ block.settings.button_link | default: '#' }}" 
                    class="button {% if block.settings.button_style == 'link' %}button--link{% else %}button--primary{% endif %}"
                    {% if block.settings.button_link == blank %}onclick="return false;"{% endif %}
                  >
                    {{ block.settings.button_label }}
                  </a>
                </div>
              </div>
            {% endif %}
        {% endcase %}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
