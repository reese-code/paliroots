{% stylesheet %}
  .image-with-text {
    display: flex;
    gap: var(--image-with-text-gap);
    align-items: center;
  }

  /* Layout direction control */
  .image-with-text--normal {
    flex-direction: row;
  }

  .image-with-text--flipped {
    flex-direction: row-reverse;
  }

  /* Responsive behavior */
  @media screen and (max-width: 749px) {
    .image-with-text,
    .image-with-text--flipped {
      flex-direction: column;
    }
  }

  /* Sizing options */
  .image-with-text--equal .image-with-text__image,
  .image-with-text--equal .image-with-text__content {
    flex: 1;
  }

  .image-with-text--text-one-third .image-with-text__content {
    flex: 1;
  }

  .image-with-text--text-one-third .image-with-text__image {
    flex: 2;
  }

  .image-with-text--image-one-third .image-with-text__image {
    flex: 1;
  }

  .image-with-text--image-one-third .image-with-text__content {
    flex: 2;
  }

  /* Image styling */
  .image-with-text__image {
    position: relative;
    overflow: hidden;
  }

  .image-with-text__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .image-with-text__image:hover img {
    transform: scale(1.02);
  }

  .image-with-text__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-foreground), 0.04);
    color: rgba(var(--color-foreground), 0.75);
    min-height: 400px;
    aspect-ratio: 4 / 3;
  }

  /* Content styling */
  .image-with-text__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
  }

  .image-with-text__heading {
    margin: 0;
  }

  .image-with-text__text {
    margin: 0;
    line-height: 1.6;
  }

  .image-with-text__button {
    margin-top: 0.5rem;
  }

  /* Link wrapper */
  .image-with-text__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .image-with-text__content {
      padding: 1rem 0;
    }
    
    .image-with-text__placeholder {
      min-height: 300px;
    }
  }
{% endstylesheet %}

<div
  class="section section--{{ section.settings.section_width }} image-with-text-section spacing-style"
  style="
    {%- render 'spacing-style', settings: section.settings -%}
    {%- render 'border-override', settings: section.settings -%}
    --image-with-text-gap: {{ section.settings.gap }}px;
  "
>
  <div class="image-with-text image-with-text--{{ section.settings.layout_direction }} image-with-text--{{ section.settings.sizing_option }}">
    
    <!-- Image Section -->
    <div class="image-with-text__image">
      {% if section.settings.image %}
        {% if section.settings.image_link != blank %}
          <a href="{{ section.settings.image_link }}" class="image-with-text__link">
        {% endif %}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '300, 450, 600, 750, 900, 1050, 1200, 1350, 1500',
            sizes: 'auto, (min-width: 750px) 50vw, 100vw',
            alt: section.settings.image.alt | default: 'Featured image'
        }}
        {% if section.settings.image_link != blank %}
          </a>
        {% endif %}
      {% else %}
        <div class="image-with-text__placeholder">
          <span>Add Image</span>
        </div>
      {% endif %}
    </div>

    <!-- Content Section -->
    <div class="image-with-text__content">
      {% if section.settings.heading != blank %}
        <h2 class="image-with-text__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="image-with-text__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <div class="image-with-text__button">
          <a 
            href="{{ section.settings.button_link | default: '#' }}" 
            class="button {% if section.settings.button_style == 'link' %}button--link{% else %}button--primary{% endif %}"
            {% if section.settings.button_link == blank %}onclick="return false;"{% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Image with Text",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_direction",
      "label": "Layout direction",
      "options": [
        {
          "value": "normal",
          "label": "Image left, text right"
        },
        {
          "value": "flipped",
          "label": "Text left, image right"
        }
      ],
      "default": "normal",
      "info": "On mobile, content will always stack vertically"
    },
    {
      "type": "select",
      "id": "sizing_option",
      "label": "Column sizing",
      "options": [
        {
          "value": "equal",
          "label": "Equal (50/50)"
        },
        {
          "value": "text-one-third",
          "label": "Text 1/3, Image 2/3"
        },
        {
          "value": "image-one-third",
          "label": "Image 1/3, Text 2/3"
        }
      ],
      "default": "equal",
      "info": "Controls the width ratio between image and text"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image and text",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32,
      "info": "Space between the image and text content"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image link",
      "info": "Optional: make the image clickable"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h4",
          "label": "Small"
        },
        {
          "value": "h3",
          "label": "Medium"
        },
        {
          "value": "h2",
          "label": "Large"
        },
        {
          "value": "h1",
          "label": "Extra large"
        }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Leave blank to hide button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "button",
          "label": "Button"
        },
        {
          "value": "link",
          "label": "Link"
        }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "category": "Image",
      "settings": {
        "layout_direction": "normal",
        "sizing_option": "equal",
        "gap": 32,
        "heading": "Image with text",
        "text": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
        "button_label": "Shop now"
      }
    },
    {
      "name": "Image with text - Text focus",
      "category": "Image", 
      "settings": {
        "layout_direction": "flipped",
        "sizing_option": "text-one-third",
        "gap": 40,
        "heading": "Our story",
        "text": "<p>Use this section to tell your brand story. Share your values, mission, and what makes your products special.</p>",
        "button_label": "Learn more"
      }
    },
    {
      "name": "Image with text - Image focus",
      "category": "Image",
      "settings": {
        "layout_direction": "normal",
        "sizing_option": "image-one-third", 
        "gap": 24,
        "heading": "Featured product",
        "text": "<p>Highlight your best-selling or newest product with this image and text combination.</p>",
        "button_label": "Shop now"
      }
    }
  ]
}
{% endschema %}