[
  {
    "name": "theme_info",
    "theme_name": "PALIROOTS",
    "theme_version": "1.0.1", 
    "theme_author": "PALIROOTS",
    "theme_documentation_url": "https://paliroots.com",
    "theme_support_url": "https://paliroots.com/support"
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "logo_inverse",
        "label": "Logo (White Version)",
        "info": "Used on dark backgrounds or hero sections"
      },
      {
        "type": "image_picker", 
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Site Content",
    "settings": [
      {
        "type": "header",
        "content": "Navigation Menu"
      },
      {
        "type": "text",
        "id": "nav_shop_text",
        "label": "Shop Menu Text",
        "default": "Shop"
      },
      {
        "type": "text", 
        "id": "nav_lookbook_text",
        "label": "Lookbook Menu Text",
        "default": "LOOKBOOK"
      },
      {
        "type": "text",
        "id": "nav_story_text", 
        "label": "Our Story Menu Text",
        "default": "Our Story"
      },
      {
        "type": "text",
        "id": "nav_philanthropy_text",
        "label": "Philanthropy Menu Text", 
        "default": "PHILANTHROPY"
      },
      {
        "type": "header",
        "content": "Button Text"
      },
      {
        "type": "text",
        "id": "default_cta_text",
        "label": "Default Call-to-Action Text",
        "default": "Shop now"
      },
      {
        "type": "text",
        "id": "add_to_cart_text",
        "label": "Add to Cart Text", 
        "default": "Add to cart"
      },
      {
        "type": "text",
        "id": "view_all_text",
        "label": "View All Products Text",
        "default": "View all"
      },
      {
        "type": "header",
        "content": "Footer"
      },
      {
        "type": "textarea",
        "id": "footer_text",
        "label": "Footer Description",
        "default": "PALIROOTS - Premium streetwear inspired by California culture."
      },
      {
        "type": "text",
        "id": "copyright_text",
        "label": "Copyright Text",
        "default": "© 2024 PALIROOTS. All rights reserved."
      }
    ]
  },
  {
    "name": "Basic Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background", 
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "foreground",
            "label": "Text Color",
            "default": "#000000"
          },
          {
            "type": "color",
            "id": "primary",
            "label": "Primary/Accent Color",
            "default": "#000000"
          },
          {
            "type": "color",
            "id": "primary_button_background",
            "label": "Button Background",
            "default": "#000000"
          },
          {
            "type": "color", 
            "id": "primary_button_text",
            "label": "Button Text",
            "default": "#FFFFFF"
          }
        ],
        "role": {
          "text": "foreground",
          "background": "background", 
          "links": "primary",
          "primary_button": "primary_button_background",
          "on_primary_button": "primary_button_text"
        }
      }
    ]
  },
  {
    "name": "Cart & Checkout",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Style",
        "options": [
          {
            "value": "page",
            "label": "Page"
          },
          {
            "value": "drawer", 
            "label": "Slide-out Drawer"
          }
        ],
        "default": "page"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "Allow order notes",
        "default": false
      }
    ]
  }
]