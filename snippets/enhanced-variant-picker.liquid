{% comment %}
  Enhanced Variant Picker with improved layout and conditional functionality
  @param {product} product_resource - The product resource object.
{% endcomment %}

{% stylesheet %}
  .enhanced-variant-picker {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .enhanced-variant-picker__option-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .enhanced-variant-picker__label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-foreground);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .enhanced-variant-picker__options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .enhanced-variant-picker__option {
    position: relative;
    cursor: pointer;
  }

  .enhanced-variant-picker__option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .enhanced-variant-picker__option-label {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-variant-border);
    border-radius: 4px;
    background-color: var(--color-variant-background);
    color: var(--color-variant-text);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .enhanced-variant-picker__option-label:hover {
    background-color: var(--color-variant-hover-background);
    border-color: var(--color-variant-hover-border);
    color: var(--color-variant-hover-text);
  }

  .enhanced-variant-picker__option input:checked + .enhanced-variant-picker__option-label {
    background-color: var(--color-selected-variant-background);
    border-color: var(--color-selected-variant-border);
    color: var(--color-selected-variant-text);
  }

  .enhanced-variant-picker__option input:checked + .enhanced-variant-picker__option-label:hover {
    background-color: var(--color-selected-variant-hover-background);
    border-color: var(--color-selected-variant-hover-border);
    color: var(--color-selected-variant-hover-text);
  }

  .enhanced-variant-picker__option--unavailable .enhanced-variant-picker__option-label {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .enhanced-variant-picker__option--unavailable .enhanced-variant-picker__option-label:hover {
    background-color: var(--color-variant-background);
    border-color: var(--color-variant-border);
    color: var(--color-variant-text);
  }

{% endstylesheet %}

{% unless product_resource.has_only_default_variant %}
  {% liquid
    # Sort options: colors first, then size, then everything else
    assign sorted_options = product_resource.options_with_values
    assign color_options = ''
    assign size_options = ''
    assign other_options = ''
    
    for option in product_resource.options_with_values
      assign option_name_lower = option.name | downcase
      if option_name_lower contains 'color' or option_name_lower contains 'colour'
        assign color_options = color_options | append: option.name | append: ','
      elsif option_name_lower contains 'size'
        assign size_options = size_options | append: option.name | append: ','
      else
        assign other_options = other_options | append: option.name | append: ','
      endif
    endfor

    assign has_size_requirement = false
    if size_options != '' and settings.enable_conditional_purchase
      assign has_size_requirement = true
    endif
  %}

  <enhanced-variant-picker 
    class="enhanced-variant-picker"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product_resource.id }}"
    data-block-id="{{ block.id }}"
    data-product-url="{{ product_resource.url }}"
    data-has-size-requirement="{{ has_size_requirement }}"
    {% if product.id == product_resource.id %}
      data-template-product-match="true"
    {% endif %}
    {{ block.shopify_attributes }}
  >
    <form class="enhanced-variant-picker__form">
      {% comment %} Display color options first {% endcomment %}
      {% if settings.show_colors_first and color_options != '' %}
        {% for product_option in product_resource.options_with_values %}
          {% assign option_name_lower = product_option.name | downcase %}
          {% if option_name_lower contains 'color' or option_name_lower contains 'colour' %}
            {% unless settings.hide_empty_options and product_option.values.size == 0 %}
              <div class="enhanced-variant-picker__option-group">
                <label class="enhanced-variant-picker__label">{{ product_option.name | escape }}</label>
                <div class="enhanced-variant-picker__options" data-option-name="{{ product_option.name | escape }}">
                  {% for product_option_value in product_option.values %}
                    <div class="enhanced-variant-picker__option{% unless product_option_value.available %} enhanced-variant-picker__option--unavailable{% endunless %}">
                      <input
                        type="radio"
                        name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                        value="{{ product_option_value | escape }}"
                        id="{{ product_option.name | handleize }}-{{ product_option_value | handleize }}-{{ block.id }}-{{ product_resource.id }}"
                        data-option-position="{{ product_option.position }}"
                        data-option-value="{{ product_option_value | escape }}"
                        {% if product_option_value.available == false %}
                          disabled
                        {% endif %}
                        {% if product_option_value.selected %}
                          checked
                        {% endif %}
                      >
                      <label 
                        class="enhanced-variant-picker__option-label"
                        for="{{ product_option.name | handleize }}-{{ product_option_value | handleize }}-{{ block.id }}-{{ product_resource.id }}"
                      >
                        {% if product_option_value.swatch %}
                          {% render 'swatch', swatch: product_option_value.swatch %}
                        {% else %}
                          {{ product_option_value | escape }}
                        {% endif %}
                      </label>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endunless %}
          {% endif %}
        {% endfor %}
      {% endif %}

      {% comment %} Display size options {% endcomment %}
      {% if size_options != '' %}
        {% for product_option in product_resource.options_with_values %}
          {% assign option_name_lower = product_option.name | downcase %}
          {% if option_name_lower contains 'size' %}
            {% unless settings.hide_empty_options and product_option.values.size == 0 %}
              <div class="enhanced-variant-picker__option-group">
                <label class="enhanced-variant-picker__label">{{ product_option.name | escape }}</label>
                <div class="enhanced-variant-picker__options" data-option-name="{{ product_option.name | escape }}">
                  {% for product_option_value in product_option.values %}
                    <div class="enhanced-variant-picker__option{% unless product_option_value.available %} enhanced-variant-picker__option--unavailable{% endunless %}">
                      <input
                        type="radio"
                        name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                        value="{{ product_option_value | escape }}"
                        id="{{ product_option.name | handleize }}-{{ product_option_value | handleize }}-{{ block.id }}-{{ product_resource.id }}"
                        data-option-position="{{ product_option.position }}"
                        data-option-value="{{ product_option_value | escape }}"
                        data-is-size="true"
                        {% if product_option_value.available == false %}
                          disabled
                        {% endif %}
                        {% if product_option_value.selected %}
                          checked
                        {% endif %}
                      >
                      <label 
                        class="enhanced-variant-picker__option-label"
                        for="{{ product_option.name | handleize }}-{{ product_option_value | handleize }}-{{ block.id }}-{{ product_resource.id }}"
                      >
                        {{ product_option_value | escape }}
                      </label>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endunless %}
          {% endif %}
        {% endfor %}
      {% endif %}

      {% comment %} Display other options {% endcomment %}
      {% for product_option in product_resource.options_with_values %}
        {% assign option_name_lower = product_option.name | downcase %}
        {% unless option_name_lower contains 'color' or option_name_lower contains 'colour' or option_name_lower contains 'size' %}
          {% unless settings.hide_empty_options and product_option.values.size == 0 %}
            <div class="enhanced-variant-picker__option-group">
              <label class="enhanced-variant-picker__label">{{ product_option.name | escape }}</label>
              <div class="enhanced-variant-picker__options" data-option-name="{{ product_option.name | escape }}">
                {% for product_option_value in product_option.values %}
                  <div class="enhanced-variant-picker__option{% unless product_option_value.available %} enhanced-variant-picker__option--unavailable{% endunless %}">
                    <input
                      type="radio"
                      name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                      value="{{ product_option_value | escape }}"
                      id="{{ product_option.name | handleize }}-{{ product_option_value | handleize }}-{{ block.id }}-{{ product_resource.id }}"
                      data-option-position="{{ product_option.position }}"
                      data-option-value="{{ product_option_value | escape }}"
                      {% if product_option_value.available == false %}
                        disabled
                      {% endif %}
                      {% if product_option_value.selected %}
                        checked
                      {% endif %}
                    >
                    <label 
                      class="enhanced-variant-picker__option-label"
                      for="{{ product_option.name | handleize }}-{{ product_option_value | handleize }}-{{ block.id }}-{{ product_resource.id }}"
                    >
                      {{ product_option_value | escape }}
                    </label>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endunless %}
        {% endunless %}
      {% endfor %}


      <script type="application/json" data-variant-json>
        {{ product_resource.selected_or_first_available_variant | json }}
      </script>

      <script type="application/json" data-product-json>
        {{ product_resource.variants | json }}
      </script>
    </form>
  </enhanced-variant-picker>

  <script>
    class EnhancedVariantPicker extends HTMLElement {
      constructor() {
        super();
        this.form = this.querySelector('.enhanced-variant-picker__form');
        this.variantData = JSON.parse(this.querySelector('[data-variant-json]').textContent);
        this.productVariants = JSON.parse(this.querySelector('[data-product-json]').textContent);
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.querySelectorAll('input[type="radio"]').forEach(input => {
          input.addEventListener('change', this.handleOptionChange.bind(this));
        });
      }

      handleOptionChange(event) {
        this.updateVariant();
        this.dispatchVariantChangeEvent();
      }

      updateVariant() {
        const selectedOptions = {};
        this.querySelectorAll('input[type="radio"]:checked').forEach(input => {
          const optionName = input.name.split('-')[0];
          selectedOptions[optionName] = input.value;
        });

        // Find matching variant
        const matchingVariant = this.productVariants.find(variant => {
          return variant.options.every((option, index) => {
            const optionName = `option${index + 1}`;
            return selectedOptions[optionName] === option;
          });
        });

        if (matchingVariant) {
          this.variantData = matchingVariant;
        }
      }

      dispatchVariantChangeEvent() {
        const changeEvent = new CustomEvent('enhanced-variant:change', {
          detail: {
            variant: this.variantData
          },
          bubbles: true
        });
        this.dispatchEvent(changeEvent);
      }
    }

    customElements.define('enhanced-variant-picker', EnhancedVariantPicker);
  </script>
{% endunless %}