<!-- PALIROOTS Custom Navigation -->
<nav class="tw-flex tw-items-center">
  <div class="tw-flex tw-gap-8 tw-items-center">
    {% for link in linklists['main-menu'].links %}
      <a href="{{ link.url }}" class="paliroots-nav-link tw-font-neue-montreal tw-font-normal tw-text-base tw-text-black tw-no-underline tw-transition-opacity tw-duration-200 hover:tw-opacity-70{% if link.title contains 'LOOKBOOK' or link.title contains 'PHILANTHROPY' %} tw-uppercase{% endif %}">
        {{ link.title }}
      </a>
    {% endfor %}
  </div>
</nav>

{% stylesheet %}
/* Transparent header overrides */
.template-index .header[transparent] .paliroots-nav-link {
  color: white !important;
}

/* Mobile navigation */
@media screen and (max-width: 749px) {
  nav.tw-flex {
    display: none;
  }
}
{% endstylesheet %}