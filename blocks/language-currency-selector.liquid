{% stylesheet %}
  .language-currency-selector {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .language-currency-selector--horizontal {
    flex-direction: row;
    align-items: center;
    gap: 1rem;
  }

  .selector-dropdown {
    position: relative;
    width: 100%;
  }

  .selector-dropdown select {
    width: 100%;
    padding: 1rem 3rem 1rem 1.5rem;
    border: 2px solid var(--custom-border-color, #000000);
    border-radius: 0;
    background-color: var(--custom-background-color, #f8f8f8);
    color: var(--custom-text-color, #000000);
    font-size: 1rem;
    font-weight: 500;
    appearance: none;
    cursor: pointer;
    position: relative;
    z-index: 1;
    line-height: 1.5;
  }

  .selector-dropdown select option {
    color: #000000 !important;
    background-color: #ffffff !important;
    padding: 0.5rem;
    font-size: 1rem;
    line-height: 1.5;
  }
  
  /* Ensure text is visible across browsers */
  .selector-dropdown select {
    color: var(--custom-text-color, #000000) !important;
  }
  
  /* Webkit specific option styling */
  .selector-dropdown select option:checked {
    background-color: #007bff !important;
    color: #ffffff !important;
  }

  .selector-dropdown::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 1.5rem;
    transform: translateY(-50%);
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 6px solid var(--custom-text-color, #000000);
    pointer-events: none;
    z-index: 2;
  }

  .selector-dropdown select:focus {
    outline: none;
    border-color: var(--custom-border-color, #000000);
    box-shadow: 0 0 0 2px rgba(from var(--custom-border-color, #000000) r g b / 0.2);
  }

  /* Horizontal layout adjustments */
  .language-currency-selector--horizontal .selector-dropdown {
    flex: 1;
    max-width: 300px;
  }

  @media screen and (width < 750px) {
    /* Remove the mobile stacking - keep horizontal layout on mobile */
    .language-currency-selector--horizontal .selector-dropdown {
      max-width: none;
    }
  }
{% endstylesheet %}

<div 
  class="language-currency-selector language-currency-selector--{{ block.settings.layout }}"
  style="
    {% if block.settings.custom_background_color != blank %}--custom-background-color: {{ block.settings.custom_background_color }};{% endif %}
    {% if block.settings.custom_border_color != blank %}--custom-border-color: {{ block.settings.custom_border_color }};{% endif %}
    {% if block.settings.custom_text_color != blank %}--custom-text-color: {{ block.settings.custom_text_color }};{% endif %}
  "
  {{ block.shopify_attributes }}
>
  <!-- Language Selector -->
  <div class="selector-dropdown">
    <select
      name="locale_code"
      aria-label="Language"
    >
      <option 
        value="en" 
        {% if localization.language.iso_code == 'en' %}selected{% endif %}
      >
        English
      </option>
      <option 
        value="es" 
        {% if localization.language.iso_code == 'es' %}selected{% endif %}
      >
        Spanish
      </option>
    </select>
  </div>

  <!-- Currency Selector -->
  <div class="selector-dropdown">
    <select
      name="currency_code"
      aria-label="Currency"
    >
      <option 
        value="USD" 
        {% if localization.currency.iso_code == 'USD' %}selected{% endif %}
      >
        USD / $
      </option>
      <option 
        value="CAD" 
        {% if localization.currency.iso_code == 'CAD' %}selected{% endif %}
      >
        CAD / $
      </option>
    </select>
  </div>
</div>

{% schema %}
{
  "name": "Language & Currency",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "vertical",
          "label": "Vertical (stacked)"
        },
        {
          "value": "horizontal",
          "label": "Horizontal (side-by-side on all screens)"
        }
      ],
      "default": "vertical"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "custom_background_color",
      "label": "Background Color",
      "info": "Leave empty for transparent background"
    },
    {
      "type": "color",
      "id": "custom_border_color",
      "label": "Border Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "custom_text_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Language & Currency",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}