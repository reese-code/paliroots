{
  "name": "paliroots-shopify-theme",
  "version": "1.0.0",
  "description": "Horizon Shopify theme with Tailwind CSS and GSAP",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:shopify": "shopify theme dev --store=paliroots-dev",
    "dev:css": "tailwindcss -i ./src/styles/main.css -o ./assets/tailwind.css --watch",
    "dev:js": "esbuild src/scripts/main.js --bundle --outfile=assets/bundle.js --watch --sourcemap",
    "build": "npm-run-all build:*",
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./assets/tailwind.css --minify",
    "build:js": "esbuild src/scripts/main.js --bundle --outfile=assets/bundle.js --minify",
    "push": "npm run build && shopify theme push --store=paliroots-dev",
    "pull": "shopify theme pull --store=paliroots-dev"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "esbuild": "^0.19.8",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6"
  },
  "dependencies": {
    "gsap": "^3.12.2"
  },
  "keywords": ["shopify", "theme", "tailwind", "gsap"],
  "author": "Paliroots",
  "license": "ISC",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}